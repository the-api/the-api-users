{
  "name": "the-api-users",
  "version": "0.3.6",
  "license": "MIT",
  "author": "Dimitry Ivanov <2@ivanoff.org.ua> # curl -A cv ivanoff.org.ua",
  "description": "Users for the-api",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-api/the-api-users.git"
  },
  "keywords": ["the-api", "users", "login", "registration", "authentication", "authorization"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "migrations",
    "migrationsUpdate",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target=node --external @hono/oauth-providers --external the-api-routings && tsc",
    "prepack": "bun run build",
    "test": "bun test tests/login.spec.ts tests/oauth.spec.ts tests/users.spec.ts"
  },
  "dependencies": {
    "@hono/oauth-providers": "0.8.5",
    "the-api-routings": "^0.6.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "the-api": "^22.9.6",
    "the-api-roles": "^1.1.2"
  }
}
